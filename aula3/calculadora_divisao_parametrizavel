/*********
  Calculadora com divisao parametrizável (2 a 32 bits) - ESP32
  Cálculo feito no microcontrolador em C/C++
  Medição simples do tempo de cada operação
*********/

#include <WiFi.h>
#include <stdlib.h>

const char* ssid     = "Calculadora ESP32 Grupo G";
const char* password = "123456789";

WiFiServer server(80);
String header;

// Estado da aplicação
String resultadoStr = "-";
bool temOverflow = false;
long resultadoInt = 0;
unsigned long ultimoTempoUs = 0;

// --------------------------------------------------
// Utilidades
// --------------------------------------------------
long long valorMinimoBits(int bits) {
  return -(1LL << (bits - 1));
}

long long valorMaximoBits(int bits) {
  return (1LL << (bits - 1)) - 1;
}

String getQueryValue(const String& request, const String& key) {
  int start = request.indexOf(key);
  if (start < 0) return "";

  start += key.length();
  int endAmp = request.indexOf('&', start);
  int endSpace = request.indexOf(' ', start);

  int end = -1;
  if (endAmp >= 0 && endSpace >= 0) end = min(endAmp, endSpace);
  else if (endAmp >= 0) end = endAmp;
  else if (endSpace >= 0) end = endSpace;
  else end = request.length();

  return request.substring(start, end);
}

long parseLongQuery(const String& request, const String& key) {
  String value = getQueryValue(request, key);
  if (value.length() == 0) return 0;
  return strtol(value.c_str(), nullptr, 10);
}

void atualizarOperacao(int bits, const String& op, long v1, long v2) {
  temOverflow = false;
  resultadoStr = "-";
  resultadoInt = 0;
  ultimoTempoUs = 0;

  long long minVal = valorMinimoBits(bits);
  long long maxVal = valorMaximoBits(bits);

  if (op == "som") {
    unsigned long inicio = micros();

    if ((long long)v1 < minVal || (long long)v1 > maxVal ||
        (long long)v2 < minVal || (long long)v2 > maxVal) {
      temOverflow = true;
    } else {
      long long r = (long long)v1 + (long long)v2;
      if (r < minVal || r > maxVal) {
        temOverflow = true;
      } else {
        resultadoInt = (long)r;
        resultadoStr = String(resultadoInt);
      }
    }

    ultimoTempoUs = micros() - inicio;
  }
  else if (op == "sub") {
    unsigned long inicio = micros();

    if ((long long)v1 < minVal || (long long)v1 > maxVal ||
        (long long)v2 < minVal || (long long)v2 > maxVal) {
      temOverflow = true;
    } else {
      long long r = (long long)v1 - (long long)v2;
      if (r < minVal || r > maxVal) {
        temOverflow = true;
      } else {
        resultadoInt = (long)r;
        resultadoStr = String(resultadoInt);
      }
    }

    ultimoTempoUs = micros() - inicio;
  }
  else if (op == "mul") {
    unsigned long inicio = micros();

    if ((long long)v1 < minVal || (long long)v1 > maxVal ||
        (long long)v2 < minVal || (long long)v2 > maxVal) {
      temOverflow = true;
    } else {
      long long r = (long long)v1 * (long long)v2;
      if (r < minVal || r > maxVal) {
        temOverflow = true;
      } else {
        resultadoInt = (long)r;
        resultadoStr = String(resultadoInt);
      }
    }

    ultimoTempoUs = micros() - inicio;
  }
  else if (op == "div") {
    unsigned long inicio = micros();

    if ((long long)v1 < minVal || (long long)v1 > maxVal ||
        (long long)v2 < minVal || (long long)v2 > maxVal) {
      temOverflow = true;
    } else if (v2 == 0) {
      temOverflow = true;
    } else if ((long long)v1 == minVal && (long long)v2 == -1) {
      temOverflow = true;
    } else {
      long long r = (long long)v1 / (long long)v2;
      if (r < minVal || r > maxVal) {
        temOverflow = true;
      } else {
        resultadoInt = (long)r;
        resultadoStr = String(resultadoInt);
      }
    }

    ultimoTempoUs = micros() - inicio;
  }
  else if (op == "fat") {
    unsigned long inicio = micros();

    if (v1 < 0 || (long long)v1 > maxVal) {
      temOverflow = true;
    } else {
      long long fat = 1;
      for (long i = 2; i <= v1; i++) {
        if (fat > maxVal / i) {
          temOverflow = true;
          break;
        }
        fat *= i;
      }

      if (!temOverflow) {
        resultadoInt = (long)fat;
        resultadoStr = String(resultadoInt);
      }
    }

    ultimoTempoUs = micros() - inicio;
  }
}

